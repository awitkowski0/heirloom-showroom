{% doc %}
  @prompt
    Create a two-step variant selector for a Shopify product page for a premium furniture brand. Replace the default variant selector with this custom component. It must work as follows:
    
    STEP 1 - Wood Type selection:
    - Display Option1 values (wood types: e.g. Red Wood, Brown Maple, Cherry) as clickable buttons or cards
    - Only one wood type can be selected at a time
    - Selecting a wood type filters the available color swatches in Step 2
    
    STEP 2 - Color swatch selection:
    - After a wood type is selected, show only the color swatches for variants that match that wood type (Option1)
    - Each variant has a metafield reference to a color metaobject. Determine which metafield to use based on product.vendor: if vendor is "OCS" use `custom.ocs_color_options`, if vendor is "PCL" use `custom.color_option_pcl`
    - The color metaobject (type: color_option) has fields: `color_name` (single_line_text_field), `hex_value` (color), `swatch_image` (file_reference), `vendor` (single_line_text_field)
    - Display swatches as images (swatch_image primary, hex_value colored circle as fallback)
    - Only one color can be selected at a time
    - Selecting a color swatch selects the exact matching variant (wood type + color combo)
    
    CART GATING:
    - The Add to Cart button must remain disabled until both a wood type AND a color have been selected
    - Show a clear message like "Select a wood type and color to continue" until both are chosen
    
    PLACEMENT:
    - This block must be placed on the product page template, inside the product form, replacing or wrapping the existing variant option selectors
    - Do NOT place this on the home page or any collection page
    
    STYLING:
    - Clean, minimal, premium furniture brand aesthetic
    - Wood type buttons should be text-based with an active/selected state
    - Color swatches should be square thumbnails with a selected state (border or checkmark overlay)
    - Show the selected color name as text below the swatches
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-variant-selector-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin-bottom: 20px;
  }

  .ai-variant-selector__step-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-variant-selector__label-{{ ai_gen_id }} {
    display: block;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 12px;
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-variant-selector__wood-options-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .ai-variant-selector__wood-button-{{ ai_gen_id }} {
    padding: 12px 20px;
    background-color: {{ block.settings.wood_button_bg }};
    color: {{ block.settings.wood_button_text }};
    border: {{ block.settings.wood_button_border_width }}px solid {{ block.settings.wood_button_border }};
    border-radius: {{ block.settings.wood_button_radius }}px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .ai-variant-selector__wood-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.wood_button_hover_bg }};
    border-color: {{ block.settings.wood_button_hover_border }};
  }

  .ai-variant-selector__wood-button-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.wood_button_active_bg }};
    color: {{ block.settings.wood_button_active_text }};
    border-color: {{ block.settings.wood_button_active_border }};
  }

  .ai-variant-selector__color-swatches-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .ai-variant-selector__swatch-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-variant-selector__swatch-button-{{ ai_gen_id }} {
    width: {{ block.settings.swatch_size }}px;
    height: {{ block.settings.swatch_size }}px;
    padding: 0;
    border: {{ block.settings.swatch_border_width }}px solid {{ block.settings.swatch_border }};
    border-radius: {{ block.settings.swatch_radius }}px;
    cursor: pointer;
    overflow: hidden;
    background-color: #f4f4f4;
    transition: all 0.2s ease;
    position: relative;
  }

  .ai-variant-selector__swatch-button-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.swatch_hover_border }};
    transform: scale(1.05);
  }

  .ai-variant-selector__swatch-button-{{ ai_gen_id }}.active {
    border-color: {{ block.settings.swatch_active_border }};
    border-width: {{ block.settings.swatch_active_border_width }}px;
  }

  .ai-variant-selector__swatch-button-{{ ai_gen_id }}.active::after {
    content: '✓';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: {{ block.settings.swatch_checkmark_color }};
    font-size: 18px;
    font-weight: bold;
    text-shadow: 0 0 3px rgba(0, 0, 0, 0.3);
  }

  .ai-variant-selector__swatch-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-variant-selector__swatch-color-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    border-radius: {{ block.settings.swatch_radius }}px;
  }

  .ai-variant-selector__swatch-wrapper-{{ ai_gen_id }}.disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  .ai-variant-selector__selected-color-{{ ai_gen_id }} {
    margin-top: 8px;
    font-size: 13px;
    color: {{ block.settings.selected_color_text }};
    min-height: 18px;
  }

  .ai-variant-selector__message-{{ ai_gen_id }} {
    margin-top: 16px;
    padding: 12px 16px;
    background-color: {{ block.settings.message_bg }};
    color: {{ block.settings.message_text }};
    border-radius: {{ block.settings.message_radius }}px;
    font-size: 14px;
    text-align: center;
  }

  .ai-variant-selector__hidden-select-{{ ai_gen_id }} {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-variant-selector__wood-button-{{ ai_gen_id }} {
      padding: 10px 16px;
      font-size: 13px;
    }

    .ai-variant-selector__swatch-button-{{ ai_gen_id }} {
      width: {{ block.settings.swatch_size | times: 0.85 }}px;
      height: {{ block.settings.swatch_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<variant-selector-{{ ai_gen_id }}
  class="ai-variant-selector-{{ ai_gen_id }}"
  data-product-id="{{ product.id }}"
  data-current-variant="{{ product.selected_or_first_available_variant.id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-variant-selector__step-{{ ai_gen_id }}">
    <label class="ai-variant-selector__label-{{ ai_gen_id }}">
      {{ block.settings.wood_type_label }}
    </label>
    <div class="ai-variant-selector__wood-options-{{ ai_gen_id }}">
      {% assign wood_types = '' %}
      {% for variant in product.variants %}
        {% assign wood_type = variant.option1 %}
        {% unless wood_types contains wood_type %}
          {% if wood_types != '' %}
            {% assign wood_types = wood_types | append: '||' %}
          {% endif %}
          {% assign wood_types = wood_types | append: wood_type %}
        {% endunless %}
      {% endfor %}

      {% assign wood_types_array = wood_types | split: '||' %}
      {% for wood_type in wood_types_array %}
        <button
          type="button"
          class="ai-variant-selector__wood-button-{{ ai_gen_id }}"
          data-wood-type="{{ wood_type | escape }}"
        >
          {{ wood_type }}
        </button>
      {% endfor %}
    </div>
  </div>

  <div class="ai-variant-selector__step-{{ ai_gen_id }}">
    <label class="ai-variant-selector__label-{{ ai_gen_id }}">
      {{ block.settings.color_label }}
    </label>
    <div class="ai-variant-selector__color-swatches-{{ ai_gen_id }}">
      {% for variant in product.variants %}
        {% liquid
          if product.vendor == 'OCS'
            assign color_metaobject = variant.metafields.custom.ocs_color_options.value
          elsif product.vendor == 'PCL'
            assign color_metaobject = variant.metafields.custom.color_option_pcl.value
          else
            assign color_metaobject = nil
          endif
        %}

        <div
          class="ai-variant-selector__swatch-wrapper-{{ ai_gen_id }} disabled"
          data-variant-id="{{ variant.id }}"
          data-wood-type="{{ variant.option1 | escape }}"
          data-color-name="{% if color_metaobject %}{{ color_metaobject.color_name | escape }}{% else %}{{ variant.option2 | escape }}{% endif %}"
        >
          <button
            type="button"
            class="ai-variant-selector__swatch-button-{{ ai_gen_id }}"
            data-variant-id="{{ variant.id }}"
            aria-label="{% if color_metaobject %}{{ color_metaobject.color_name | escape }}{% else %}{{ variant.option2 | escape }}{% endif %}"
          >
            {% if color_metaobject and color_metaobject.swatch_image %}
              <img
                src="{{ color_metaobject.swatch_image | image_url: width: 100 }}"
                alt="{{ color_metaobject.color_name | escape }}"
                class="ai-variant-selector__swatch-image-{{ ai_gen_id }}"
                loading="lazy"
              >
            {% elsif color_metaobject and color_metaobject.hex_value %}
              <div
                class="ai-variant-selector__swatch-color-{{ ai_gen_id }}"
                style="background-color: {{ color_metaobject.hex_value }};"
              ></div>
            {% else %}
              <div
                class="ai-variant-selector__swatch-color-{{ ai_gen_id }}"
                style="background-color: #cccccc;"
              ></div>
            {% endif %}
          </button>
        </div>
      {% endfor %}
    </div>
    <div class="ai-variant-selector__selected-color-{{ ai_gen_id }}"></div>
  </div>

  <div class="ai-variant-selector__message-{{ ai_gen_id }}">
    {{ block.settings.selection_message }}
  </div>

  <select
    name="id"
    class="ai-variant-selector__hidden-select-{{ ai_gen_id }}"
    data-variant-select
  >
    {% for variant in product.variants %}
      <option
        value="{{ variant.id }}"
        {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
      >
        {{ variant.title }}
      </option>
    {% endfor %}
  </select>
</variant-selector-{{ ai_gen_id }}>

<script>
  (function() {
    class VariantSelector{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.selectedWoodType = null;
        this.selectedVariantId = null;
      }

      connectedCallback() {
        this.woodButtons = this.querySelectorAll('.ai-variant-selector__wood-button-{{ ai_gen_id }}');
        this.swatchWrappers = this.querySelectorAll('.ai-variant-selector__swatch-wrapper-{{ ai_gen_id }}');
        this.swatchButtons = this.querySelectorAll('.ai-variant-selector__swatch-button-{{ ai_gen_id }}');
        this.messageElement = this.querySelector('.ai-variant-selector__message-{{ ai_gen_id }}');
        this.selectedColorElement = this.querySelector('.ai-variant-selector__selected-color-{{ ai_gen_id }}');
        this.hiddenSelect = this.querySelector('[data-variant-select]');

        this.setupEventListeners();
        this.updateAddToCartButton();
      }

      setupEventListeners() {
        this.woodButtons.forEach((button) => {
          button.addEventListener('click', () => {
            this.selectWoodType(button.dataset.woodType);
          });
        });

        this.swatchButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const wrapper = button.closest('.ai-variant-selector__swatch-wrapper-{{ ai_gen_id }}');
            if (!wrapper.classList.contains('disabled')) {
              this.selectVariant(button.dataset.variantId, wrapper.dataset.colorName);
            }
          });
        });
      }

      selectWoodType(woodType) {
        this.selectedWoodType = woodType;

        this.woodButtons.forEach((btn) => {
          if (btn.dataset.woodType === woodType) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });

        this.swatchWrappers.forEach((wrapper) => {
          const swatchButton = wrapper.querySelector('.ai-variant-selector__swatch-button-{{ ai_gen_id }}');
          if (wrapper.dataset.woodType === woodType) {
            wrapper.classList.remove('disabled');
          } else {
            wrapper.classList.add('disabled');
            swatchButton.classList.remove('active');
          }
        });

        this.selectedVariantId = null;
        this.selectedColorElement.textContent = '';
        this.updateAddToCartButton();
      }

      selectVariant(variantId, colorName) {
        this.selectedVariantId = variantId;

        this.swatchButtons.forEach((btn) => {
          if (btn.dataset.variantId === variantId) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });

        this.selectedColorElement.textContent = colorName;

        this.hiddenSelect.value = variantId;
        this.hiddenSelect.dispatchEvent(new Event('change', { bubbles: true }));

        this.updateAddToCartButton();
      }

      updateAddToCartButton() {
        const form = this.closest('form');
        if (!form) return;

        const addToCartButton = form.querySelector('[name="add"]');
        if (!addToCartButton) return;

        const isComplete = this.selectedWoodType && this.selectedVariantId;

        if (isComplete) {
          addToCartButton.disabled = false;
          this.messageElement.style.display = 'none';
        } else {
          addToCartButton.disabled = true;
          this.messageElement.style.display = 'block';
        }
      }
    }

    customElements.define('variant-selector-{{ ai_gen_id }}', VariantSelector{{ ai_gen_id }});
  })();
</script>

