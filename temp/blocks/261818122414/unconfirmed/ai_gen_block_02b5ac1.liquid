{% doc %}
  @prompt
    Generate a list of links to the policies pages
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-policy-links-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-policy-links__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-policy-links__list-{{ ai_gen_id }} {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.link_spacing }}px;
    {% if block.settings.layout == 'row' %}
      flex-wrap: wrap;
      justify-content: {{ block.settings.text_alignment }};
    {% endif %}
  }

  .ai-policy-links__item-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-policy-links__link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: {{ block.settings.link_style }};
    font-size: {{ block.settings.link_size }}px;
    transition: color 0.2s ease;
    display: inline-block;
  }

  .ai-policy-links__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-policy-links__separator-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    opacity: 0.5;
    {% if block.settings.layout == 'column' %}
      display: none;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-policy-links__list-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'column' %}
        flex-direction: column;
      {% endif %}
    }

    .ai-policy-links__separator-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'column' %}
        display: none;
      {% endif %}
    }
  }
{% endstyle %}

<div class="ai-policy-links-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-policy-links__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <ul class="ai-policy-links__list-{{ ai_gen_id }}">
    {% if block.settings.show_privacy_policy and shop.privacy_policy %}
      <li class="ai-policy-links__item-{{ ai_gen_id }}">
        <a href="{{ shop.privacy_policy.url }}" class="ai-policy-links__link-{{ ai_gen_id }}">
          {{ shop.privacy_policy.title }}
        </a>
      </li>
      {% if block.settings.show_separator and block.settings.layout == 'row' %}
        <li class="ai-policy-links__separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator_text }}</li>
      {% endif %}
    {% endif %}

    {% if block.settings.show_refund_policy and shop.refund_policy %}
      <li class="ai-policy-links__item-{{ ai_gen_id }}">
        <a href="{{ shop.refund_policy.url }}" class="ai-policy-links__link-{{ ai_gen_id }}">
          {{ shop.refund_policy.title }}
        </a>
      </li>
      {% if block.settings.show_separator and block.settings.layout == 'row' %}
        <li class="ai-policy-links__separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator_text }}</li>
      {% endif %}
    {% endif %}

    {% if block.settings.show_terms_of_service and shop.terms_of_service %}
      <li class="ai-policy-links__item-{{ ai_gen_id }}">
        <a href="{{ shop.terms_of_service.url }}" class="ai-policy-links__link-{{ ai_gen_id }}">
          {{ shop.terms_of_service.title }}
        </a>
      </li>
      {% if block.settings.show_separator and block.settings.layout == 'row' %}
        <li class="ai-policy-links__separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator_text }}</li>
      {% endif %}
    {% endif %}

    {% if block.settings.show_shipping_policy and shop.shipping_policy %}
      <li class="ai-policy-links__item-{{ ai_gen_id }}">
        <a href="{{ shop.shipping_policy.url }}" class="ai-policy-links__link-{{ ai_gen_id }}">
          {{ shop.shipping_policy.title }}
        </a>
      </li>
      {% if block.settings.show_separator and block.settings.layout == 'row' %}
        <li class="ai-policy-links__separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator_text }}</li>
      {% endif %}
    {% endif %}

    {% if block.settings.show_contact_info and shop.contact_information %}
      <li class="ai-policy-links__item-{{ ai_gen_id }}">
        <a href="{{ shop.contact_information.url }}" class="ai-policy-links__link-{{ ai_gen_id }}">
          {{ shop.contact_information.title }}
        </a>
      </li>
    {% endif %}
  </ul>
</div>

{% schema %}
{
  "name": "Policy links",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 18
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Heading spacing",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_privacy_policy",
      "label": "Show privacy policy",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_refund_policy",
      "label": "Show refund policy",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_terms_of_service",
      "label": "Show terms of service",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_shipping_policy",
      "label": "Show shipping policy",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_contact_info",
      "label": "Show contact information",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        {
          "value": "row",
          "label": "Horizontal"
        },
        {
          "value": "column",
          "label": "Vertical"
        }
      ],
      "default": "row"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "row",
          "label": "Horizontal"
        },
        {
          "value": "column",
          "label": "Vertical"
        }
      ],
      "default": "column"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "link_spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Link spacing",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show separator",
      "default": true
    },
    {
      "type": "text",
      "id": "separator_text",
      "label": "Separator text",
      "default": "|"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fcf9f4"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#442a22"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#442a22"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#75584d"
    },
    {
      "type": "range",
      "id": "link_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Link size",
      "default": 14
    },
    {
      "type": "select",
      "id": "link_style",
      "label": "Link style",
      "options": [
        {
          "value": "none",
          "label": "No underline"
        },
        {
          "value": "underline",
          "label": "Underline"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Vertical padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Policy links"
    }
  ]
}
{% endschema %}
