{% comment %}
  Custom Variant Picker - Uses actual Shopify variant images
  
  Images are automatically pulled from each variant's featured image
  No metafields needed - just set variant images in Shopify admin
  Shows pill style when no image available
  
  Usage:
  {% render 'custom-variant-picker', product: product, block: block, product_form_id: product_form_id %}
{% endcomment %}

{%- unless product.has_only_default_variant -%}
  <script type="application/json" data-all-variants hidden>
    [
    {%- for variant in product.variants -%}
      {%- unless forloop.first -%},{%- endunless -%}
      {
        "id": {{ variant.id }},
        "title": {{ variant.title | json }},
        "price": {{ variant.price }},
        "compare_at_price": {% if variant.compare_at_price %}{{ variant.compare_at_price }}{% else %}null{% endif %},
        "featured_image": {% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 | json }}{% else %}null{% endif %},
        "options": {{ variant.options | json }},
        "available": {{ variant.available }}
      }
    {%- endfor -%}
    ]
  </script>
  <script type="application/json" data-base-price hidden>
    {{ product.price | json }}
  </script>

  <div 
    class="custom-variant-picker" 
    id="CustomVariantPicker-{{ section.id }}"
    data-section-id="{{ section.id }}"
    data-image-style="{{ block.settings.custom_image_style | default: 'image' }}"
    {{ block.shopify_attributes }}
  >

    {%- for option in product.options_with_values -%}
      <div class="custom-option" data-option-index="{{ forloop.index0 }}" data-option-name="{{ option.name }}">
        <label class="form__label">
          {{ option.name }}
          <span class="custom-option__selected-value" data-selected-value>
            {{- option.selected_value -}}
          </span>
        </label>
        
        <div class="custom-option__values">
          {%- for value in option.values -%}
            {%- liquid
              assign is_available = false
              assign option_image = nil
              
              # Find a variant with this option value that has an image and is available
              for variant in product.variants
                if variant.options[forloop.index0] == value
                  if variant.available
                    assign is_available = true
                  endif
                  if variant.featured_image != nil and option_image == nil
                    assign option_image = variant.featured_image | image_url: width: 120
                  endif
                endif
              endfor
              
              assign has_image = false
              if option_image != nil
                assign has_image = true
              endif
            -%}
            
            <label 
              class="custom-option__value {% if value.selected %}custom-option__value--selected{% endif %} {% unless is_available %}custom-option__value--disabled{% endunless %} {% if has_image %}custom-option__value--image{% else %}custom-option__value--pill{% endif %}"
              data-value="{{ value | escape }}"
              data-value-index="{{ forloop.index0 }}"
              {% if option_image %}data-option-image="{{ option_image }}"{% endif %}
            >
              <input 
                type="radio" 
                name="Option-{{ section.id }}-{{ forloop.index0 }}"
                value="{{ value | escape }}"
                {% if value.selected %}checked{% endif %}
                {% unless is_available %}disabled{% endunless %}
                class="visually-hidden"
              >
              
              {% if has_image %}
                <span class="custom-option__image-wrapper">
                  <img 
                    src="{{ option_image }}" 
                    alt="{{ value }}"
                    class="custom-option__image"
                    loading="lazy"
                  >
                </span>
              {% endif %}
              
              <span class="custom-option__label">
                {{ value }}
              </span>
              
              {% unless is_available %}
                <span class="custom-option__unavailable visually-hidden">
                  {{- 'products.product.variant_sold_out_or_unavailable' | t -}}
                </span>
              {% endunless %}
            </label>
          {%- endfor -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
{%- endunless -%}