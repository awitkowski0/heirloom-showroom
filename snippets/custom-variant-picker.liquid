{% comment %}
  Custom Variant Picker with images and price modifiers
  
  Usage:
  {% render 'custom-variant-picker', product: product, block: block, product_form_id: product_form_id %}
  
  Metafields expected on each option value:
  - custom.variant_image: Image for the variant (applied when this option is selected)
  - custom.price_modifier: Number (positive or negative) to add to base price
{% endcomment %}

{%- unless product.has_only_default_variant -%}
  <div 
    class="custom-variant-picker" 
    id="CustomVariantPicker-{{ section.id }}"
    data-section-id="{{ section.id }}"
    {{ block.shopify_attributes }}
  >
    {%- for option in product.options_with_values -%}
      <div class="custom-option" data-option-index="{{ forloop.index0 }}" data-option-name="{{ option.name }}">
        <label class="form__label">
          {{ option.name }}
          <span class="custom-option__selected-value" data-selected-value>
            {{- option.selected_value -}}
          </span>
        </label>
        
        <div class="custom-option__values">
          {%- for value in option.values -%}
            {%- liquid
              assign option_value = option.name | append: '::' | append: value
              assign variant_image = nil
              assign price_modifier = 0
              
              # Get metafields from the option value
              # Option values in Shopify can have metafields attached
              assign option_value_obj = null
              for ov in product.options_with_values
                if ov.name == option.name
                  for v in ov.values
                    if v == value
                      assign option_value_obj = v
                      break
                    endif
                  endfor
                  break
                endif
              endfor
              
              if option_value_obj != null
                if option_value_obj.metafields.custom.variant_image != blank
                  assign variant_image = option_value_obj.metafields.custom.variant_image
                endif
                if option_value_obj.metafields.custom.price_modifier != blank
                  assign price_modifier = option_value_obj.metafields.custom.price_modifier | default: 0
                endif
              endif
              
              assign option_disabled = true
              if value.available
                assign option_disabled = false
              endif
            -%}
            
            <label 
              class="custom-option__value {% if value.selected %}custom-option__value--selected{% endif %} {% if option_disabled %}custom-option__value--disabled{% endif %}"
              data-value="{{ value | escape }}"
              data-value-index="{{ forloop.index0 }}"
              {% if variant_image != nil %}data-variant-image="{{ variant_image | image_url }}"{% endif %}
              {% if price_modifier != 0 %}data-price-modifier="{{ price_modifier }}"{% endif %}
            >
              <input 
                type="radio" 
                name="Option-{{ section.id }}-{{ forloop.parentloop.index0 }}"
                value="{{ value | escape }}"
                {% if value.selected %}checked{% endif %}
                {% if option_disabled %}disabled{% endif %}
                class="visually-hidden"
              >
              
              {% if variant_image != nil %}
                <span class="custom-option__image-wrapper">
                  <img 
                    src="{{ variant_image | image_url: width: 80 }}" 
                    alt="{{ value }}"
                    class="custom-option__image"
                    loading="lazy"
                  >
                </span>
              {% endif %}
              
              <span class="custom-option__label">
                {{ value }}
                {% if price_modifier != 0 %}
                  <span class="custom-option__price-modifier">
                    {% if price_modifier > 0 %}+{% endif %}{{ price_modifier | money }}
                  </span>
                {% endif %}
              </span>
              
              {% if option_disabled %}
                <span class="custom-option__unavailable visually-hidden">
                  {{- 'products.product.variant_sold_out_or_unavailable' | t -}}
                </span>
              {% endif %}
            </label>
          {%- endfor -%}
        </div>
      </div>
    {%- endfor -%}
    
    <script type="application/json" data-base-price>
      {{ product.price | json }}
    </script>
    <script type="application/json" data-selected-variant>
      {{ product.selected_or_first_available_variant | json }}
    </script>
  </div>

  <style>
    .custom-variant-picker {
      margin-bottom: 2rem;
    }
    
    .custom-option {
      margin-bottom: 1.5rem;
    }
    
    .custom-option .form__label {
      display: block;
      margin-bottom: 0.8rem;
      font-weight: 600;
    }
    
    .custom-option__selected-value {
      font-weight: 400;
      color: rgba(var(--color-foreground), 0.75);
    }
    
    .custom-option__values {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }
    
    .custom-option__value {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1rem;
      border: 0.1rem solid rgba(var(--color-foreground), 0.2);
      border-radius: var(--variant-pills-radius);
      cursor: pointer;
      transition: all var(--duration-short) ease;
      min-width: 100px;
      background-color: rgb(var(--color-background));
    }
    
    .custom-option__value:hover {
      border-color: rgb(var(--color-foreground));
    }
    
    .custom-option__value--selected {
      border-color: rgb(var(--color-foreground));
      background-color: rgb(var(--color-foreground));
      color: rgb(var(--color-background));
    }
    
    .custom-option__value--disabled {
      opacity: 0.5;
      cursor: not-allowed;
      text-decoration: line-through;
    }
    
    .custom-option__image-wrapper {
      width: 60px;
      height: 60px;
      margin-bottom: 0.5rem;
      border-radius: 4px;
      overflow: hidden;
      background-color: rgb(var(--color-background));
    }
    
    .custom-option__value--selected .custom-option__image-wrapper {
      border: 2px solid rgb(var(--color-background));
    }
    
    .custom-option__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .custom-option__label {
      font-size: 1.2rem;
      text-align: center;
    }
    
    .custom-option__price-modifier {
      display: block;
      font-size: 1rem;
      opacity: 0.8;
      margin-top: 0.2rem;
    }
    
    @media screen and (max-width: 749px) {
      .custom-option__values {
        gap: 0.8rem;
      }
      
      .custom-option__value {
        min-width: 80px;
        padding: 0.8rem;
      }
      
      .custom-option__image-wrapper {
        width: 50px;
        height: 50px;
      }
    }
  </style>
{%- endunless -%}