{{ 'section-terms-popup.css' | asset_url | stylesheet_tag }}
<script src="{{ 'terms-popup.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .terms-popup {
    --popup-z-index: 9999;
    --terms-title-size: {{ section.settings.terms_title_size }}px;
    --terms-content-size: {{ section.settings.terms_content_size }}px;
  }
{%- endstyle -%}

{%- if section.settings.enable_terms_popup -%}
  <div class="terms-popup-overlay" id="terms-popup-overlay" data-enabled="{{ section.settings.enable_terms_popup }}">
    <div class="terms-popup" id="terms-popup" role="dialog" aria-modal="true" aria-labelledby="terms-popup-title">
      <div class="terms-popup__content">
        <h2 class="terms-popup__title" id="terms-popup-title" style="font-size: {{ section.settings.terms_title_size }}px;">
          {{ section.settings.terms_title | default: 'Terms of Service' }}
        </h2>
        <div class="terms-popup__body" style="font-size: {{ section.settings.terms_content_size }}px;">
          {{ section.settings.terms_content }}
        </div>
        <div class="terms-popup__actions">
          <div class="terms-popup__links">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <a href="{{ policy.url }}" class="terms-popup__link">
                  {{ policy.title }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <div class="terms-popup__buttons">
            <button type="button" class="button button--primary" id="terms-accept">
              {{ section.settings.accept_button_text | default: 'I Accept' }}
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Terms Popup",
  "class": "terms-popup-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_terms_popup",
      "default": true,
      "label": "Enable Terms Acceptance Popup"
    },
    {
      "type": "text",
      "id": "terms_title",
      "default": "Terms of Service",
      "label": "Popup Title"
    },
    {
      "type": "range",
      "id": "terms_title_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "default": 32,
      "label": "Title Font Size (px)"
    },
    {
      "type": "richtext",
      "id": "terms_content",
      "default": "<p>By continuing to browse and use this website, you agree to our terms and conditions.</p>",
      "label": "Popup Content"
    },
    {
      "type": "range",
      "id": "terms_content_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 18,
      "label": "Content Font Size (px)"
    },
    {
      "type": "text",
      "id": "accept_button_text",
      "default": "I Accept",
      "label": "Accept Button Text"
    }
  ],
  "presets": [
    {
      "name": "Terms Popup"
    }
  ]
}
{% endschema %}
