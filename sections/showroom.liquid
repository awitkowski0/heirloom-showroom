{{ 'section-showroom.css' | asset_url | stylesheet_tag }}
<script src="{{ 'showroom.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .showroom__hotspot {
    --parallax-intensity: {{ section.settings.parallax_intensity }}px;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="title-wrapper title-wrapper--no-top-margin title-wrapper--{{ section.settings.heading_alignment }}">
        <h2 class="title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="showroom{% if section.settings.enable_parallax %} showroom--parallax{% endif %}" data-section-id="{{ section.id }}">
      <div class="showroom__image-container">
        <div class="showroom__image-wrapper">
          {%- if section.settings.room_image != blank -%}
            {%- assign widths = '165, 360, 535, 750, 1070, 1500, 1780, 2000, 3000' -%}
            {%- capture sizes -%}
              (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px,
              (min-width: 750px) 100vw, 100vw
            {%- endcapture -%}
            {{
              section.settings.room_image
              | image_url: width: 2000
              | image_tag: sizes: sizes, widths: widths, class: 'showroom__image', fetchpriority: 'high'
            }}
          {%- else -%}
            {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg showroom__image showroom__image--placeholder' }}
          {%- endif -%}

          <div class="showroom__hotspots">
            {%- for block in section.blocks -%}
              {%- assign product = block.settings.product -%}
              {%- if product != blank -%}
                <a
                  href="{{ product.url }}"
                  class="showroom__hotspot"
                  style="--pos-x: {{ block.settings.position_x }}%; --pos-y: {{ block.settings.position_y }}%;"
                  {{ block.shopify_attributes }}
                >
                  <span class="showroom__hotspot-dot"></span>
                  <span class="showroom__hotspot-label">
                    {%- if block.settings.label != blank -%}
                      {{ block.settings.label }}
                    {%- else -%}
                      {{ product.title | escape }}
                    {%- endif -%}
                  </span>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        {%- if section.settings.enable_parallax -%}
          <div class="showroom__parallax-bg" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Showroom",
  "class": "section",
  "max_blocks": 20,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Room Image"
    },
    {
      "type": "image_picker",
      "id": "room_image",
      "label": "Room Photo"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Room"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Heading Alignment"
    },
    {
      "type": "header",
      "content": "Parallax Effect"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "default": true,
      "label": "Enable Parallax"
    },
    {
      "type": "range",
      "id": "parallax_intensity",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 20,
      "label": "Parallax Intensity",
      "info": "Controls the depth effect on hover"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "Color Scheme"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label Override",
          "info": "Leave blank to use product title"
        },
        {
          "type": "range",
          "id": "position_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "label": "Horizontal Position"
        },
        {
          "type": "range",
          "id": "position_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "label": "Vertical Position"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Showroom",
      "blocks": [
        {
          "type": "hotspot"
        }
      ]
    }
  ]
}
{% endschema %}
